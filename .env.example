# Ka-ching! 環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# === Anthropic Claude API ===
# 取得：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# === Google Gemini API ===
# 取得：https://ai.google.dev/
GEMINI_API_KEY=...

# === Line Messaging API ===
# 取得：https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_CHANNEL_SECRET=...

# === News API（可選） ===
# 取得：https://newsapi.org/
NEWS_API_KEY=...

# === 應用設定 ===
TIMEZONE=Asia/Taipei
LOG_LEVEL=INFO
